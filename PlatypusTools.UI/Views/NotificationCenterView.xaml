<UserControl x:Class="PlatypusTools.UI.Views.NotificationCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:PlatypusTools.UI.Services"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="4,4,4,8">
            <TextBlock Text="🔔 Notification Center" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock x:Name="CountText" Text="" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,0,4,8">
            <Button Content="🔄 Refresh" Width="90" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Content="✓ Mark all read" Width="120" Margin="0,0,8,0" Click="MarkAllRead_Click"/>
            <Button Content="🗑️ Clear history" Width="120" Margin="0,0,8,0" Click="ClearHistory_Click"
                    Background="#FFF44336" Foreground="White"/>
            <Button Content="📂 Open log folder" Width="140" Margin="0,0,8,0" Click="OpenFolder_Click"/>
            <ComboBox x:Name="FilterCombo" Width="140" SelectedIndex="0" SelectionChanged="Filter_Changed"
                      ToolTip="Filter by severity">
                <ComboBoxItem Content="All severities"/>
                <ComboBoxItem Content="Info"/>
                <ComboBoxItem Content="Success"/>
                <ComboBoxItem Content="Warning"/>
                <ComboBoxItem Content="Error"/>
            </ComboBox>
            <TextBox x:Name="SearchBox" Width="220" Margin="8,0,0,0"
                     TextChanged="Search_TextChanged" VerticalContentAlignment="Center"
                     ToolTip="Filter by text">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Resources>
                            <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                <VisualBrush.Visual>
                                    <TextBlock Text="🔎 Search messages…" Foreground="Gray" Margin="4,0,0,0"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="HistoryGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  AlternatingRowBackground="#15808080" RowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Severity" Binding="{Binding Type}" Width="90"/>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="220"/>
                <DataGridTemplateColumn Header="Message" Width="*" MinWidth="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Message}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <StatusBar Grid.Row="3" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="History persisted to %APPDATA%\PlatypusTools\notification-history.json (last 500 entries)."/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
