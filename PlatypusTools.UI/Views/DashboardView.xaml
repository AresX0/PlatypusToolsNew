<UserControl x:Class="PlatypusTools.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PlatypusTools.UI.ViewModels"
             Background="{DynamicResource WindowBackgroundBrush}"
             Foreground="{DynamicResource WindowForegroundBrush}">
    
    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel Margin="16">
            
            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/platypus.png" Width="40" Height="40" VerticalAlignment="Center" ToolTip="Platypus" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="{Binding Greeting}" FontSize="24" FontWeight="Light"/>
                        <TextBlock Text="{Binding CurrentTime}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AppVersion}" VerticalAlignment="Bottom" Margin="16,0,0,4" 
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                </StackPanel>
                <ToggleButton Content="🎛️ Customize" HorizontalAlignment="Right" VerticalAlignment="Center"
                              IsChecked="{Binding IsCustomizePanelOpen}" Padding="10,6" MinWidth="110"/>
            </Grid>

            <!-- Widget Customization Panel -->
            <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                    Padding="12" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    Visibility="{Binding IsCustomizePanelOpen, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock Text="🎛️ Dashboard Widgets" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Text="Toggle widgets on or off to customize your dashboard" 
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <CheckBox Content="⚡ Quick Actions" IsChecked="{Binding ShowQuickActions}" Margin="0,0,16,6"/>
                        <CheckBox Content="🎵 Now Playing" IsChecked="{Binding ShowNowPlaying}" Margin="0,0,16,6"/>
                        <CheckBox Content="💾 Disk Usage" IsChecked="{Binding ShowDiskUsage}" Margin="0,0,16,6"/>
                        <CheckBox Content="📊 System Status" IsChecked="{Binding ShowSystemStatus}" Margin="0,0,16,6"/>
                        <CheckBox Content="🌐 Remote Server" IsChecked="{Binding ShowRemoteServer}" Margin="0,0,16,6"/>
                        <CheckBox Content="↩️ Undo Stack" IsChecked="{Binding ShowUndoStack}" Margin="0,0,16,6"/>
                        <CheckBox Content="⌨️ Keyboard Shortcuts" IsChecked="{Binding ShowKeyboardShortcuts}" Margin="0,0,16,6"/>
                        <CheckBox Content="🆕 New Features" IsChecked="{Binding ShowNewFeatures}" Margin="0,0,16,6"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                    Padding="16" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                    Visibility="{Binding ShowQuickActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="⚡ Quick Actions" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Content="⚙️  Settings" Padding="12,8" Margin="0,0,8,8" 
                                Command="{Binding OpenSettingsCommand}" MinWidth="120"/>
                        <Button Content="🔍  Search" Padding="12,8" Margin="0,0,8,8" 
                                Command="{Binding OpenCommandPaletteCommand}" MinWidth="120"/>
                        <Button Content="🔄  Check Updates" Padding="12,8" Margin="0,0,8,8" 
                                Command="{Binding CheckForUpdatesCommand}" MinWidth="120"/>
                        <Button Content="🔃  Refresh" Padding="12,8" Margin="0,0,8,8" 
                                Command="{Binding RefreshCommand}" MinWidth="120"/>
                        <Button Content="🖼️  Apply Next Wallpaper" Padding="12,8" Margin="0,0,8,8"
                                Command="{Binding ApplyNextWallpaperCommand}" MinWidth="160"
                                Background="#FFFF9800" Foreground="White"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">
                    
                    <!-- Now Playing -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                            Padding="16" Margin="0,0,0,12"
                            BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Visibility="{Binding ShowNowPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="🎵 Now Playing" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding NowPlayingTitle}" FontSize="16" FontWeight="SemiBold" 
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding NowPlayingArtist}" Foreground="{DynamicResource SecondaryTextBrush}" 
                                       FontSize="13" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Disk Usage -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                            Padding="16" Margin="0,0,0,12"
                            BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Visibility="{Binding ShowDiskUsage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="💾 Disk Usage" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding DiskUsage}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding DisplayText}" FontSize="12" Margin="0,0,0,3"/>
                                            <Grid Height="8">
                                                <Border Background="#33808080" CornerRadius="4"/>
                                                <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" 
                                                        HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PercentToWidthConverter}" 
                                                                      FallbackValue="100">
                                                            <Binding Path="UsedPercent"/>
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">
                    
                    <!-- System Status -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                            Padding="16" Margin="0,0,0,12"
                            BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Visibility="{Binding ShowSystemStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="📊 System Status" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CpuUsage}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="CPU" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MemoryUsage}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="RAM" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding UptimeDisplay}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Uptime" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Server Status -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                            Padding="16" Margin="0,0,0,12"
                            BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Visibility="{Binding ShowRemoteServer, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="🌐 Remote Server" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#DC3545"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                                    <Setter Property="Fill" Value="#28A745"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding ServerStatus}" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Undo History -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                            Padding="16" Margin="0,0,0,12"
                            BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Visibility="{Binding ShowUndoStack, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4">
                                <Run Text="↩️ Undo Stack: "/>
                                <Run Text="{Binding UndoCount, Mode=OneWay}"/>
                                <Run Text=" operation(s)"/>
                            </TextBlock>
                            <TextBlock Text="Press Ctrl+Z to undo" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- New Features (v4.0.2.x) -->
            <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                    Padding="16" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    Visibility="{Binding ShowNewFeatures, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="🆕 New Features" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Text="Recently added tools and capabilities" 
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Content="🖼️  Wallpaper Rotator" Padding="12,8" Margin="0,0,8,8"
                                Command="{Binding OpenWallpaperRotatorCommand}" MinWidth="160"
                                Background="#FF2196F3" Foreground="White"
                                ToolTip="Rotate desktop wallpaper + lock screen with NASA Artemis overlay"/>
                        <Button Content="🌌  Slideshow Screensaver" Padding="12,8" Margin="0,0,8,8"
                                Command="{Binding OpenScreensaverCommand}" MinWidth="180"
                                Background="#FF9C27B0" Foreground="White"
                                ToolTip="Image slideshow screensaver, install as Windows .scr"/>
                        <Button Content="🛡️  AD Security Analyzer" Padding="12,8" Margin="0,0,8,8"
                                Command="{Binding OpenAdSecurityCommand}" MinWidth="180"
                                Background="#FF4CAF50" Foreground="White"
                                ToolTip="Active Directory security posture analyzer"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Keyboard Shortcuts Reference -->
            <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" 
                    Padding="16" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                    Visibility="{Binding ShowKeyboardShortcuts, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="⌨️ Keyboard Shortcuts" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <TextBlock Margin="0,0,24,4" FontSize="12"><Run FontWeight="SemiBold">Ctrl+K</Run><Run Text="  Search"/></TextBlock>
                        <TextBlock Margin="0,0,24,4" FontSize="12"><Run FontWeight="SemiBold">Ctrl+Shift+P</Run><Run Text="  Command Palette"/></TextBlock>
                        <TextBlock Margin="0,0,24,4" FontSize="12"><Run FontWeight="SemiBold">Ctrl+Z</Run><Run Text="  Undo"/></TextBlock>
                        <TextBlock Margin="0,0,24,4" FontSize="12"><Run FontWeight="SemiBold">Ctrl+,</Run><Run Text="  Settings"/></TextBlock>
                        <TextBlock Margin="0,0,24,4" FontSize="12"><Run FontWeight="SemiBold">Ctrl+1-6</Run><Run Text="  Switch Tab"/></TextBlock>
                        <TextBlock Margin="0,0,24,4" FontSize="12"><Run FontWeight="SemiBold">F11</Run><Run Text="  Fullscreen"/></TextBlock>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
