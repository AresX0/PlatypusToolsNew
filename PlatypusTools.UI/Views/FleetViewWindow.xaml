<Window x:Class="PlatypusTools.UI.Views.FleetViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛰️ Fleet View" Height="520" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Subnet:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="SubnetBox" Width="160" Text="192.168.1" ToolTip="First three octets, e.g. 192.168.1"/>
            <TextBlock Text="Port:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox x:Name="PortBox" Width="80" Text="47392"/>
            <Button Content="🔎 Scan LAN" Click="Scan_Click" MinWidth="100" Margin="12,0,0,0"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button Content="🛑 Stop" Click="Stop_Click" MinWidth="60" Margin="6,0,0,0"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#888" Text="Idle"/>
        </WrapPanel>

        <DataGrid Grid.Row="1" x:Name="FleetGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Host" Binding="{Binding Address}" Width="180"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Latency (ms)" Binding="{Binding LatencyMs}" Width="120"/>
                <DataGridTextColumn Header="Service Banner" Binding="{Binding Banner}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#888"
                   Text="Scans /24 of the chosen subnet for an HTTPS PlatypusTools Remote Server (default port 47392). Cert mismatch is ignored — this only checks the /health endpoint banner."/>
    </Grid>
</Window>
