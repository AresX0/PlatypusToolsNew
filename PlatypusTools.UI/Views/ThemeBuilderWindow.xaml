<Window x:Class="PlatypusTools.UI.Views.ThemeBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎨 Theme Builder"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        Foreground="White">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.ColumnSpan="2" Grid.Row="0" Text="Edit hex colors below. Right pane previews. Save to .xaml ResourceDictionary."
                   Margin="0,0,0,8" Foreground="#FFAAAAAA" />

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ColorListPanel" />
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" BorderBrush="#FF333333" BorderThickness="1">
            <Grid x:Name="PreviewRoot" Background="{Binding ElementName=BgBox, Path=Tag}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border x:Name="PreviewHeader" Padding="12" Background="#FF6200EA">
                    <TextBlock Text="Preview header" Foreground="White" FontSize="16" FontWeight="Bold" />
                </Border>
                <StackPanel Grid.Row="1" Margin="12">
                    <TextBlock x:Name="PreviewBody" Text="Body text" />
                    <Button x:Name="PreviewButton" Content="Primary action" Width="180" Margin="0,8,0,0" />
                    <TextBox x:Name="PreviewInput" Text="input field" Margin="0,8,0,0" />
                </StackPanel>
                <StatusBar Grid.Row="2" x:Name="PreviewStatus" Background="#FF252525">
                    <TextBlock Text="Status bar preview" Foreground="White" />
                </StatusBar>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Grid.ColumnSpan="2" LastChildFill="False" Margin="0,8,0,0">
            <Button DockPanel.Dock="Left" Content="📂 Load .xaml" Width="120" Click="Load_Click"
                    Background="#FF2196F3" Foreground="White" BorderThickness="0" Padding="6,4" />
            <Button DockPanel.Dock="Left" Margin="6,0,0,0" Content="💾 Save .xaml" Width="120" Click="Save_Click"
                    Background="#FF4CAF50" Foreground="White" BorderThickness="0" Padding="6,4" />
            <TextBox DockPanel.Dock="Right" x:Name="BgBox" Visibility="Collapsed" />
        </DockPanel>
    </Grid>
</Window>
