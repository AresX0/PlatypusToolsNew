<Window x:Class="PlatypusTools.UI.Views.WorkflowDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workflow Designer" Height="640" Width="980"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
            <Button Content="📂 Open" Click="Open_Click" MinWidth="80" Margin="0,0,6,0"/>
            <Button Content="💾 Save As" Click="SaveAs_Click" MinWidth="90" Margin="0,0,6,0"/>
            <Button Content="▶️ Run" Click="Run_Click" MinWidth="80" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,16,0"/>
            <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="NameBox" Width="240" Text="New Workflow"/>
        </WrapPanel>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Steps">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Button Content="➕ Add" Click="AddStep_Click" MinWidth="60" Margin="0,0,4,0"/>
                    <Button Content="➖ Remove" Click="RemoveStep_Click" MinWidth="80" Margin="0,0,4,0"/>
                    <Button Content="🔼" Click="MoveUp_Click" Width="34"/>
                    <Button Content="🔽" Click="MoveDown_Click" Width="34"/>
                </WrapPanel>
                <ListBox x:Name="StepsList" SelectionChanged="StepsList_SelectionChanged"/>
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Step Detail" Margin="8,0,0,0">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="TypeBox" Width="140" SelectionChanged="TypeBox_SelectionChanged"/>
                    <TextBlock Text="Name:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox x:Name="StepNameBox" Width="220" TextChanged="StepNameBox_TextChanged"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Text="Inputs (key=value per line, supports {{last}} substitution + env vars):" Margin="0,8,0,4"/>
                <TextBox Grid.Row="2" x:Name="InputsBox" Height="120" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto" TextChanged="InputsBox_TextChanged"/>
                <GroupBox Grid.Row="3" Header="Run Output" Margin="0,8,0,0">
                    <TextBox x:Name="OutputBox" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </GroupBox>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0" Foreground="#888"
                   Text="Tip: types — shell, powershell, writefile, readfile, delay, log. Env vars and {{last}} are substituted in inputs."/>
    </Grid>
</Window>
