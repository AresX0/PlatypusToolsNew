<Window x:Class="PlatypusTools.UI.Views.SmartRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✨ Smart Rename (LLM)"
        Height="620" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        Foreground="White">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="Folder:" Width="80" VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right" Content="📁 Browse" Width="90" Click="Browse_Click"
                    Background="#FF2196F3" Foreground="White" BorderThickness="0" />
            <TextBox x:Name="FolderBox" Padding="4" Margin="0,0,6,0"
                     Background="#FF252525" Foreground="White" BorderBrush="#FF444444" />
        </DockPanel>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Hint:" Width="80" VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right" Content="🤖 Suggest" Width="100" Click="Suggest_Click"
                    Background="#FF9C27B0" Foreground="White" BorderThickness="0" Padding="6,4" />
            <Button DockPanel.Dock="Right" Content="✅ Apply" Width="80" Margin="0,0,6,0" Click="Apply_Click"
                    Background="#FF4CAF50" Foreground="White" BorderThickness="0" Padding="6,4" />
            <TextBox x:Name="HintBox" Padding="4" Margin="0,0,6,0"
                     Background="#FF252525" Foreground="White" BorderBrush="#FF444444" />
        </DockPanel>

        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  Background="#FF252525" RowBackground="#FF2D2D2D" AlternatingRowBackground="#FF333333"
                  Foreground="White" HorizontalGridLinesBrush="#FF444444" BorderBrush="#FF444444">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Apply" Binding="{Binding Apply}" Width="60" />
                <DataGridTextColumn Header="Original" Binding="{Binding OriginalPath}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Suggested" Binding="{Binding SuggestedName}" Width="300" />
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="3" Background="#FF252525" Foreground="White">
            <TextBlock x:Name="StatusText" Text="Pick a folder and press Suggest." />
        </StatusBar>
    </Grid>
</Window>
