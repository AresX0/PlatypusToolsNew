<Window x:Class="PlatypusTools.UI.Views.AIAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🤖 AI Assistant (Local)" Height="640" Width="780"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Backend:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="BackendBox" Width="220" SelectionChanged="Backend_Changed">
                <ComboBoxItem Content="Ollama (loopback, local)" IsSelected="True"/>
                <ComboBoxItem Content="OpenAI-compatible (LM Studio / self-host)"/>
                <ComboBoxItem Content="Anthropic (Claude / self-host proxy)"/>
            </ComboBox>
            <TextBlock Text="Model:" VerticalAlignment="Center" Margin="16,0,6,0"/>
            <ComboBox x:Name="ModelBox" Width="180" IsEditable="True" Text="llama3.2"/>
            <Button Content="🔄 Reload models" Click="Reload_Click" Margin="6,0,0,0"/>
            <Button Content="🧹 Clear chat" Click="Clear_Click" Margin="6,0,0,0"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#888" Text="Idle"/>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="System prompt (optional):" Margin="0,0,0,4"/>
            <TextBox Grid.Row="0" x:Name="SystemBox" Margin="0,16,0,4" Height="40" AcceptsReturn="True"
                     Text="You are a concise local assistant for a Windows power user."/>
            <ListBox Grid.Row="1" x:Name="ChatLog" HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6" Margin="2" CornerRadius="4" Background="#22000000">
                            <StackPanel>
                                <TextBlock Text="{Binding Role}" FontWeight="Bold" Foreground="#7E57C2"/>
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBox Grid.Row="2" x:Name="InputBox" Height="80" Margin="0,4,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     KeyDown="InputBox_KeyDown"/>
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
            <Button Content="Send (Ctrl+Enter)" Click="Send_Click" MinWidth="140" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="HintText" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#888"
                       Text="Requires Ollama running locally (https://ollama.com) or any OpenAI-compatible /v1 endpoint."/>
        </WrapPanel>
    </Grid>
</Window>
