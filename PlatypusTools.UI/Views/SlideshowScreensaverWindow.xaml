<Window x:Class="PlatypusTools.UI.Views.SlideshowScreensaverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PlatypusTools Slideshow"
        WindowStyle="None" ResizeMode="NoResize"
        WindowState="Maximized" Topmost="True"
        Background="Black" Cursor="None"
        ShowInTaskbar="False">
    <Grid x:Name="RootGrid" Background="Black" ClipToBounds="True">
        <Image x:Name="ImageA" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" />
        <Image x:Name="ImageB" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" />
        <Border x:Name="OverlayPanel"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,20,20,0" Padding="16"
                Background="#D9000020" BorderBrush="#FF1A3A6A" BorderThickness="1"
                MaxWidth="520" MaxHeight="800"
                Visibility="Collapsed">
            <ScrollViewer x:Name="OverlayScroll"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Hidden">
                <ItemsControl x:Name="OverlayItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Brush}"
                                       FontFamily="Consolas"
                                       FontWeight="{Binding Weight}"
                                       FontSize="{Binding Size}"
                                       Margin="0,2,0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
