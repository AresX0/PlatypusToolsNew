<Window x:Class="PlatypusTools.UI.Views.PluginMarketplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧩 Plugin Marketplace"
        Height="620" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        Foreground="White">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="🔄 Refresh" Width="100" Click="Refresh_Click"
                    Background="#FF2196F3" Foreground="White" BorderThickness="0" Padding="6,4" />
            <TextBlock Text="Registry URL: " VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="UrlBox" Padding="4"
                     Background="#FF252525" Foreground="White" BorderBrush="#FF444444" />
        </DockPanel>

        <DataGrid Grid.Row="1" x:Name="Grid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#FF252525"
                  RowBackground="#FF2D2D2D"
                  AlternatingRowBackground="#FF333333"
                  Foreground="White"
                  HorizontalGridLinesBrush="#FF444444"
                  BorderBrush="#FF444444">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="160" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                <DataGridTextColumn Header="Ver" Binding="{Binding Version}" Width="70" />
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="120" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                <DataGridTemplateColumn Header="Actions" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Install" Width="80" Click="Install_Click" Tag="{Binding}"
                                        Background="#FF4CAF50" Foreground="White" BorderThickness="0" />
                                <Button Content="Homepage" Width="100" Margin="6,0,0,0" Click="Homepage_Click" Tag="{Binding}"
                                        Background="#FF2196F3" Foreground="White" BorderThickness="0" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="2" Background="#FF252525" Foreground="White">
            <TextBlock x:Name="StatusText" Text="Loading registry..." />
        </StatusBar>
    </Grid>
</Window>
