<Window x:Class="PlatypusTools.UI.Views.KeyboardShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Shortcuts" Height="540" Width="640"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⌨ Keyboard Shortcuts" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ShortcutsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#FFF0F0F0" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Key}" FontFamily="Consolas" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Description}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="90" Height="30" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
