<UserControl x:Class="PlatypusTools.UI.Views.WallpaperRotatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="🖼️ Wallpaper &amp; Lock Screen Rotator"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />

        <!-- Source folder -->
        <GroupBox Grid.Row="1" Header="Source Folder" Margin="0,0,0,4">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ImagesDirectory, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" VerticalAlignment="Center" Padding="6,4" />
                <Button Grid.Column="1" Content="📂 Browse…" Command="{Binding BrowseFolderCommand}"
                        Padding="12,4" Margin="6,0,0,0"
                        Background="#FF2196F3" Foreground="White" />
            </Grid>
        </GroupBox>

        <!-- Settings -->
        <GroupBox Grid.Row="2" Header="Settings" Margin="0,0,0,4">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Change every (sec):" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding WallpaperIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                          Width="100" HorizontalAlignment="Left" Margin="0,0,16,4" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Fit mode:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <ComboBox  Grid.Row="0" Grid.Column="3" SelectedValue="{Binding FitMode}" SelectedValuePath="Tag"
                           Width="140" HorizontalAlignment="Left" Margin="0,0,0,4">
                    <ComboBoxItem Content="Fit (letterbox)" Tag="fit" />
                    <ComboBoxItem Content="Fill (crop)" Tag="fill" />
                    <ComboBoxItem Content="Stretch" Tag="stretch" />
                    <ComboBoxItem Content="Center" Tag="center" />
                </ComboBox>

                <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="🔀 Shuffle order" IsChecked="{Binding Shuffle}" Margin="0,4,0,4" />
                <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                          Content="🔒 Also set as Lock Screen (UAC once)" IsChecked="{Binding ApplyToLockScreen}" Margin="0,4,0,4" />

                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="🚀 Run rotator at user login" IsChecked="{Binding RunAtLogin}" Margin="0,4,0,0" />
                <CheckBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                          Content="🖌️ Burn overlay onto wallpaper" IsChecked="{Binding BurnOverlayOnWallpaper}" Margin="0,4,0,0" />
            </Grid>
        </GroupBox>

        <!-- Overlay -->
        <GroupBox Grid.Row="3" Header="Overlay" Margin="0,0,0,4">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox SelectedValue="{Binding OverlaySource}" SelectedValuePath="Tag" Width="200">
                        <ComboBoxItem Content="🚀 NASA Artemis (live + cached)" Tag="nasa" />
                        <ComboBoxItem Content="✏️ Custom text" Tag="custom" />
                        <ComboBoxItem Content="🚫 None" Tag="none" />
                    </ComboBox>
                    <Button Content="🔄 Refresh NASA" Command="{Binding RefreshNasaCommand}"
                            Padding="10,4" Margin="12,0,0,0"
                            Background="#FF9C27B0" Foreground="White" />

                    <TextBlock Text="Opacity:" VerticalAlignment="Center" Margin="20,0,8,0"/>
                    <Slider Value="{Binding OverlayOpacity}" Minimum="0.2" Maximum="1.0" Width="180" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding OverlayOpacity, StringFormat={}{0:0.00}}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
                <TextBox Text="{Binding CustomOverlayText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="70"
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="One line per row. Lines starting with ═ are styled as titles. Used when Source = Custom text." />
            </StackPanel>
        </GroupBox>

        <!-- Status / Preview -->
        <GroupBox Grid.Row="4" Header="Status" Margin="0,0,0,4">
            <StackPanel Margin="8">
                <TextBlock>
                    <Run Text="Running:" FontWeight="SemiBold"/>
                    <Run Text="{Binding IsRunning}" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0">
                    <Run Text="Current image:" FontWeight="SemiBold"/>
                    <Run Text="{Binding CurrentImageDisplay}" />
                </TextBlock>
                <TextBlock Text="{Binding NextChangeText}" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </GroupBox>

        <!-- Action bar -->
        <WrapPanel Grid.Row="5" Margin="0,4,0,0">
            <Button Content="▶ Start Rotator"  Command="{Binding StartCommand}"   Padding="14,6" Margin="0,0,6,0"
                    Background="#FF4CAF50" Foreground="White" />
            <Button Content="⏸ Stop"           Command="{Binding StopCommand}"    Padding="14,6" Margin="0,0,6,0"
                    Background="#FFF44336" Foreground="White" />
            <Button Content="🖼 Apply Next Now" Command="{Binding ApplyNowCommand}" Padding="14,6" Margin="0,0,6,0"
                    Background="#FFFF9800" Foreground="White" />
            <Button Content="💾 Save Settings"  Command="{Binding SaveSettingsCommand}" Padding="14,6"
                    Background="#FF2196F3" Foreground="White" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
        </WrapPanel>
    </Grid>
</UserControl>
