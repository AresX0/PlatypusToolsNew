<UserControl x:Class="PlatypusTools.UI.Views.ScriptingConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🐚 Scripting Console"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Engine:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="EngineCombo" Width="180" SelectedIndex="0">
                <ComboBoxItem Content="PowerShell"/>
                <ComboBoxItem Content="Python"/>
            </ComboBox>
            <Button x:Name="RunButton" Content="▶ Run (Ctrl+Enter)" Margin="12,0,0,0"
                    Padding="10,3" Background="#FF4CAF50" Foreground="White"
                    Click="Run_Click"/>
            <Button x:Name="ClearButton" Content="Clear" Margin="6,0,0,0" Padding="10,3" Click="Clear_Click"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="14,0,0,0" Opacity="0.7"/>
        </StackPanel>

        <TextBox x:Name="ScriptBox" Grid.Row="2" AcceptsReturn="True" AcceptsTab="True"
                 FontFamily="Consolas" FontSize="13"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 PreviewKeyDown="ScriptBox_PreviewKeyDown"
                 Text="# Type PowerShell or Python here, then click Run.&#x0a;Get-Date"/>

        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#CCCCCC" Cursor="SizeNS"/>

        <TextBox x:Name="OutputBox" Grid.Row="4" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 Background="#FF1E1E1E" Foreground="#FFD4D4D4"
                 BorderThickness="1" BorderBrush="#FF333333"/>

        <TextBlock Grid.Row="5" Margin="0,4,0,0" Opacity="0.6"
                   Text="⚠ Scripts run in a separate process. Read-only — internal app services are not exposed."/>
    </Grid>
</UserControl>
