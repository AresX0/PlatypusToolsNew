<Window x:Class="PlatypusTools.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PlatypusTools.UI.Views"
        xmlns:vm="clr-namespace:PlatypusTools.UI.ViewModels"
        xmlns:views="clr-namespace:PlatypusTools.UI.Views"
        xmlns:controls="clr-namespace:PlatypusTools.UI.Controls"
        xmlns:services="clr-namespace:PlatypusTools.UI.Services"
        Title="PlatypusTools" Height="700" Width="1200" Icon="Assets/platypus.png"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>
    <Grid>
        <DockPanel Background="{DynamicResource WindowBackgroundBrush}">
        <Menu DockPanel.Dock="Top" Background="{DynamicResource ControlBackgroundBrush}">
            <MenuItem Header="File">
                <MenuItem Header="Open Folder..." Command="{Binding BrowseCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="Save Workspace..." Command="{Binding SaveWorkspaceCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Export Config..." Command="{Binding ExportConfigCommand}" InputGestureText="Ctrl+Shift+E" />
                <MenuItem Header="Import Config..." Command="{Binding ImportConfigCommand}" InputGestureText="Ctrl+Shift+I" />
                <Separator />
                <MenuItem Header="Recent Workspaces" x:Name="RecentWorkspacesMenu">
                    <MenuItem Header="(No recent workspaces)" IsEnabled="False" x:Name="NoRecentPlaceholder"/>
                </MenuItem>
                <MenuItem Header="Open Recent..." Command="{Binding OpenRecentWorkspacesCommand}" InputGestureText="Ctrl+R" />
                <MenuItem Header="Clear Recent List" Click="ClearRecentList_Click" />
                <Separator />
                <MenuItem Header="Backup Settings..." Click="BackupSettings" />
                <MenuItem Header="Restore Settings..." Click="RestoreSettings" />
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" InputGestureText="Alt+F4" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Fullscreen Mode" Click="ToggleFullScreen_Click" InputGestureText="F11" />
                <MenuItem Header="Auto-Hide Navigation" Click="ToggleAutoHideNavigation_Click" InputGestureText="Ctrl+H" />
                <Separator />
                <MenuItem Header="Toggle Staging Panel" Command="{Binding ToggleStagingInDuplicatesCommand}" IsCheckable="True" IsChecked="{Binding DuplicatesStagingVisible, Mode=TwoWay}" />
                <MenuItem Header="Show Preview Panel" IsCheckable="True" IsChecked="{Binding DuplicatesPreviewVisible, Mode=TwoWay}" Command="{Binding TogglePreviewPanelCommand}" />
                <Separator />
                <MenuItem Header="Dark Theme" IsCheckable="True" IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" Command="{Binding ToggleThemeCommand}" InputGestureText="Ctrl+Shift+D" />
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Open Archived Scripts" Command="{Binding OpenArchivedScriptsCommand}" />
                <Separator />
                <MenuItem Header="Run Archived Script..." Command="{Binding RunArchivedScriptCommand}" />
                <MenuItem Header="Run Parity Tests..." Command="{Binding RunParityTestsCommand}" />
                <MenuItem Header="Credential Manager..." Command="{Binding OpenCredentialManagerCommand}" />
                <Separator />
                <MenuItem Header="🔐 Unlock AD Security Analyzer..." Click="UnlockAdSecurity_Click" InputGestureText="Ctrl+Shift+A" />
                <Separator />
                <MenuItem Header="Validate DataContext" Click="ValidateDataContext_Click" />
                <Separator />
                <MenuItem Header="🔁 Workflow Designer..." Click="OpenWorkflowDesigner_Click" />
                <MenuItem Header="🤖 AI Assistant..." Click="OpenAIAssistant_Click" />
                <MenuItem Header="🛰️ Fleet View..." Click="OpenFleetView_Click" />
                <MenuItem Header="🗺️ Disk TreeMap..." Click="OpenTreeMap_Click" />
                <MenuItem Header="🎨 Theme Builder..." Click="OpenThemeBuilder_Click" />
                <MenuItem Header="🧩 Plugin Marketplace..." Click="OpenPluginMarketplace_Click" />
                <MenuItem Header="🧬 YARA Scanner..." Click="OpenYaraScanner_Click" />
                <MenuItem Header="✨ Smart Rename (LLM)..." Click="OpenSmartRename_Click" />
                <MenuItem Header="🔐 Encrypted Clipboard..." Click="OpenEncryptedClipboard_Click" />
                <MenuItem Header="📜 Activity Log..." Click="OpenActivityLog_Click" />
                <Separator />
                <MenuItem Header="Settings..." Click="OpenSettings" InputGestureText="Ctrl+," />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="View Help Documentation" Command="{Binding OpenHelpCommand}" InputGestureText="F1" />
                <Separator />
                <MenuItem Header="File Cleaner - How to Use" Click="ShowFileCleanerHelp" />
                <MenuItem Header="Video Converter - How to Use" Click="ShowVideoConverterHelp" />
                <MenuItem Header="Video Combiner - How to Use" Click="ShowVideoCombinerHelp" />
                <MenuItem Header="Duplicates Finder - How to Use" Click="ShowDuplicatesHelp" />
                <MenuItem Header="System Cleaner - How to Use" Click="ShowSystemCleanerHelp" />
                <MenuItem Header="Folder Hider - How to Use" Click="ShowFolderHiderHelp" />
                <MenuItem Header="Robocopy - How to Use" Click="ShowRobocopyHelp" />
                <Separator />
                <MenuItem Header="View Logs..." Click="OpenLogViewer" />
                <MenuItem Header="Check for Updates..." Click="CheckForUpdates" />
                <MenuItem Header="🔧 Manage Dependencies..." Click="OpenSettingsToDependencies_Click" />
                <MenuItem Header="View Changelog..." Click="ShowChangelog" />
                <Separator />
                <MenuItem Header="About PlatypusTools" Click="ShowAbout" InputGestureText="Shift+F1" />
            </MenuItem>
        </Menu>

        <Border x:Name="HeaderBorder" DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}" Padding="12,8"
                MouseEnter="NavigationArea_MouseEnter" MouseLeave="NavigationArea_MouseLeave">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Source="{Binding HeaderImage}" Width="48" Height="48" Margin="0,0,12,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource HeaderForegroundBrush}">PlatypusTools</TextBlock>
                        <TextBlock FontSize="12" Foreground="{DynamicResource HeaderForegroundBrush}" Opacity="0.8">Advanced File Management &amp; Media Tools</TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleThemeCommand}" 
                            AutomationProperties.Name="Toggle Theme"
                            MinWidth="100" Height="32" Margin="0,0,8,0"
                            BorderThickness="0" FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌓" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding CurrentThemeDisplayName, FallbackValue='Theme'}"/>
                        </StackPanel>
                    </Button>
                    <Button Content="⚙ Settings" Click="OpenSettings" 
                            Width="90" Height="32"
                            BorderThickness="0" FontWeight="SemiBold"/>
                    <Button x:Name="AutoHideButton" Click="ToggleAutoHideNavigation_Click"
                            AutomationProperties.Name="Auto-hide Navigation"
                            ToolTip="Auto-hide navigation tabs (Ctrl+H)"
                            Width="36" Height="32" Margin="8,0,0,0" Padding="4,2"
                            BorderThickness="0" FontWeight="SemiBold">
                        <TextBlock Text="📌" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Auto-Hide Reveal Bar (visible only when navigation is hidden) -->
        <Border x:Name="TabRevealBar" DockPanel.Dock="Top" Height="4" Background="#FF2196F3" 
                Visibility="Collapsed" Cursor="Hand"
                MouseEnter="TabRevealBar_MouseEnter"
                ToolTip="Hover to show navigation tabs (Ctrl+H to toggle)"/>

        <!-- Status Bar -->
        <controls:StatusBarControl DockPanel.Dock="Bottom"/>

        <TabControl x:Name="MainTabControl" DockPanel.Dock="Top" Margin="8" 
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    AutomationProperties.Name="Main Navigation"
                    MouseEnter="NavigationArea_MouseEnter" MouseLeave="NavigationArea_MouseLeave">
            <!-- Dashboard -->
            <TabItem Header="🏠 Dashboard" AutomationProperties.Name="Dashboard">
                <views:DashboardView/>
            </TabItem>
            <!-- AI Hub (v4.0.3.10 reorg — surfaces AI Assistant, Smart Rename, Workflow Designer that were buried in Tools menu) -->
            <TabItem Header="🤖 AI" AutomationProperties.Name="AI Hub">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24" MaxWidth="1100" HorizontalAlignment="Left">
                        <TextBlock Text="🤖 AI Hub" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Local-first LLM tools. All AI features can be routed to a local backend (LocalOnlyMode) — see Settings → AI to switch providers and edit API keys."
                                   TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,20"/>

                        <WrapPanel ItemWidth="340">
                            <Border Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="💬 AI Assistant" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="Chat with the configured LLM. Ask about files, generate scripts, summarize logs, or run prompts against your workspace."
                                               TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,12" MinHeight="60"/>
                                    <Button Content="Open AI Assistant" Padding="14,8" HorizontalAlignment="Left"
                                            Background="#FF2196F3" Foreground="White" Click="OpenAIAssistant_Click" ToolTip="Open the AI Assistant chat window"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="✨ Smart Rename" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="LLM-powered batch file renaming. Drop in a folder and let the model suggest descriptive, normalized names based on content."
                                               TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,12" MinHeight="60"/>
                                    <Button Content="Open Smart Rename" Padding="14,8" HorizontalAlignment="Left"
                                            Background="#FF9C27B0" Foreground="White" Click="OpenSmartRename_Click" ToolTip="Open the Smart Rename window"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="🔁 Workflow Designer" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="Build and run multi-step automation pipelines. Chain file ops, AI prompts, scripts, and conditional steps into a reusable workflow."
                                               TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,12" MinHeight="60"/>
                                    <Button Content="Open Workflow Designer" Padding="14,8" HorizontalAlignment="Left"
                                            Background="#FF4CAF50" Foreground="White" Click="OpenWorkflowDesigner_Click" ToolTip="Open the Workflow Designer"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="⚙ AI Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="Configure providers (OpenAI, Anthropic, local), API keys, default model, temperature, and the LocalOnlyMode loopback guard."
                                               TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,12" MinHeight="60"/>
                                    <Button Content="Open AI Settings" Padding="14,8" HorizontalAlignment="Left"
                                            Background="#FF607D8B" Foreground="White" Click="OpenSettingsToAI_Click" ToolTip="Open Settings → AI"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- File Management -->
            <TabItem Header="📁 File Management" 
                     AutomationProperties.Name="File Management"
                     Visibility="{Binding FileManagement, Source={x:Static services:TabVisibilityService.Instance}}">
                <TabControl AutomationProperties.Name="File Management Tabs">
                    <TabItem Header="File Cleaner" 
                             AutomationProperties.Name="File Cleaner"
                             Visibility="{Binding FileCleaner, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:FileCleanerView}" ViewDataContext="{Binding FileCleaner}" />
                    </TabItem>
                    <TabItem Header="Duplicates"
                             AutomationProperties.Name="Duplicate File Finder"
                             Visibility="{Binding Duplicates, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:DuplicatesView}" ViewDataContext="{Binding Duplicates}" />
                    </TabItem>
                    <TabItem Header="Empty Folder Scanner"
                             AutomationProperties.Name="Empty Folder Scanner"
                             Visibility="{Binding EmptyFolderScanner, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:EmptyFolderScannerView}" ViewDataContext="{Binding EmptyFolderScanner}" />
                    </TabItem>
                    <TabItem Header="Robocopy"
                             AutomationProperties.Name="Robocopy File Copy"
                             Visibility="{Binding Robocopy, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:RobocopyView}" ViewDataContext="{Binding Robocopy}" />
                    </TabItem>
                    <TabItem Header="☁ Cloud Sync"
                             AutomationProperties.Name="Cloud Sync"
                             Visibility="{Binding CloudSync, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:CloudSyncView}" ViewDataContext="{Binding CloudSync}" />
                    </TabItem>
                    <TabItem Header="File Diff"
                             AutomationProperties.Name="File Diff"
                             Visibility="{Binding FileDiff, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:FileDiffView}" ViewDataContext="{Binding FileDiff}" />
                    </TabItem>
                    <TabItem Header="Bulk File Mover"
                             AutomationProperties.Name="Bulk File Mover"
                             Visibility="{Binding BulkFileMover, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:BulkFileMoverView}" ViewDataContext="{Binding BulkFileMover}" />
                    </TabItem>
                    <TabItem Header="Symlink Manager"
                             AutomationProperties.Name="Symlink Manager"
                             Visibility="{Binding SymlinkManager, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:SymlinkManagerView}" ViewDataContext="{Binding SymlinkManager}" />
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- Multimedia (hierarchical layout) -->
            <TabItem Header="🎬 Multimedia"
                     AutomationProperties.Name="Multimedia"
                     Visibility="{Binding Multimedia, Source={x:Static services:TabVisibilityService.Instance}}">
                <TabControl>
                    <!-- Media Hub (Plex-like features) -->
                    <TabItem Header="🏠 Media Hub"
                             Visibility="{Binding MediaHub, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:MediaHubView}" ViewDataContext="{Binding MediaHub}" />
                    </TabItem>

                    <!-- Audio -->
                    <TabItem Header="🎵 Audio">
                        <TabControl>
                            <TabItem Header="Audio Player"
                                     Visibility="{Binding EnhancedAudioPlayer, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:EnhancedAudioPlayerView}" ViewDataContext="{Binding EnhancedAudioPlayer}" />
                            </TabItem>
                            <TabItem Header="Audio Trim"
                                     Visibility="{Binding AudioTrim, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:NativeAudioTrimView}" />
                            </TabItem>
                            <TabItem Header="Audio Transcription"
                                     Visibility="{Binding AudioTranscription, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:AudioTranscriptionView}" ViewDataContext="{Binding AudioTranscription}" />
                            </TabItem>
                        </TabControl>
                    </TabItem>
                    
                    <!-- Image -->
                    <TabItem Header="🖼️ Image">
                        <TabControl>
                            <TabItem Header="Image Edit"
                                     Visibility="{Binding ImageEdit, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:NativeImageEditView}" />
                            </TabItem>
                            <TabItem Header="Image Converter"
                                     Visibility="{Binding ImageConverter, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:ImageConverterView}" ViewDataContext="{Binding ImageConverter}" />
                            </TabItem>
                            <TabItem Header="Image Resizer"
                                     Visibility="{Binding ImageResizer, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:ImageResizerView}" ViewDataContext="{Binding ImageResizer}" />
                            </TabItem>
                            <TabItem Header="ICO Converter"
                                     Visibility="{Binding IconConverter, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:IconConverterView}" ViewDataContext="{Binding IconConverter}" />
                            </TabItem>
                            <TabItem Header="Batch Watermark"
                                     Visibility="{Binding BatchWatermark, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:BatchWatermarkView}" ViewDataContext="{Binding BatchWatermark}" />
                            </TabItem>
                            <TabItem Header="Image Scaler"
                                     Visibility="{Binding ImageScaler, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:BatchUpscaleView}" ViewDataContext="{Binding BatchUpscale}" />
                            </TabItem>
                            <TabItem Header="3D Model Editor"
                                     Visibility="{Binding Model3DEditor, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:Model3DEditorView}" />
                            </TabItem>
                        </TabControl>
                    </TabItem>
                    
                    <!-- Video -->
                    <TabItem Header="🎬 Video">
                        <TabControl>
                            <TabItem Header="Video Player"
                                     Visibility="{Binding VideoPlayer, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:NativeVideoPlayerView}" />
                            </TabItem>
                            <TabItem Header="Video Editor"
                                     Visibility="{Binding VideoEditor, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:ShotcutNativeEditorView}" />
                            </TabItem>
                            <TabItem Header="Upscaler"
                                     Visibility="{Binding Upscaler, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:UpscalerView}" ViewDataContext="{Binding Upscaler}" />
                            </TabItem>
                            <TabItem Header="Video Combiner"
                                     Visibility="{Binding VideoCombiner, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:VideoCombinerView}" ViewDataContext="{Binding VideoCombiner}" />
                            </TabItem>
                            <TabItem Header="Video Converter"
                                     Visibility="{Binding VideoConverter, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:VideoConverterView}" ViewDataContext="{Binding VideoConverter}" />
                            </TabItem>
                            <TabItem Header="Export Queue"
                                     Visibility="{Binding ExportQueue, Source={x:Static services:TabVisibilityService.Instance}}">
                                <views:ExportQueueView/>
                            </TabItem>
                            <TabItem Header="Video Metadata"
                                     Visibility="{Binding VideoMetadata, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:VideoMetadataView}" ViewDataContext="{Binding VideoMetadata}" />
                            </TabItem>
                            <TabItem Header="GIF Maker"
                                     Visibility="{Binding GifMaker, Source={x:Static services:TabVisibilityService.Instance}}">
                                <controls:LazyTabContent ViewType="{x:Type views:GifMakerView}" ViewDataContext="{Binding GifMaker}" />
                            </TabItem>
                        </TabControl>
                    </TabItem>
                    
                    <!-- Media Library -->
                    <TabItem Header="📚 Media Library"
                             Visibility="{Binding MediaLibrary, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:MediaLibraryView}" ViewDataContext="{Binding MediaLibrary}" />
                    </TabItem>
                    
                    <!-- External Tools (VLC, Audacity, GIMP) -->
                    <TabItem Header="🔧 External Tools"
                             Visibility="{Binding ExternalTools, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:MultimediaEditorView}" ViewDataContext="{Binding MultimediaEditor}" />
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- System -->
            <TabItem Header="🖥️ System"
                     AutomationProperties.Name="System Tools"
                     Visibility="{Binding System, Source={x:Static services:TabVisibilityService.Instance}}">
                <TabControl AutomationProperties.Name="System Tabs">
                    <TabItem Header="Disk Cleanup"
                             Visibility="{Binding DiskCleanup, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:DiskCleanupView}" ViewDataContext="{Binding DiskCleanup}" />
                    </TabItem>
                    <TabItem Header="Privacy Cleaner"
                             Visibility="{Binding PrivacyCleaner, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:PrivacyCleanerView}" ViewDataContext="{Binding PrivacyCleaner}" />
                    </TabItem>
                    <TabItem Header="Recent Cleaner"
                             Visibility="{Binding RecentCleaner, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:RecentCleanupView}" ViewDataContext="{Binding Recent}" />
                    </TabItem>
                    <TabItem Header="Startup Manager"
                             Visibility="{Binding StartupManager, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:StartupManagerView}" ViewDataContext="{Binding StartupManager}" />
                    </TabItem>
                    <TabItem Header="Process Manager"
                             Visibility="{Binding ProcessManager, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:ProcessManagerView}" ViewDataContext="{Binding ProcessManager}" />
                    </TabItem>
                    <TabItem Header="Registry Cleaner"
                             Visibility="{Binding RegistryCleaner, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:RegistryCleanerView}" ViewDataContext="{Binding RegistryCleaner}" />
                    </TabItem>
                    <TabItem Header="Scheduled Tasks"
                             Visibility="{Binding ScheduledTasks, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:ScheduledTasksView}" ViewDataContext="{Binding ScheduledTasks}" />
                    </TabItem>
                    <TabItem Header="System Restore"
                             Visibility="{Binding SystemRestore, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:SystemRestoreView}" ViewDataContext="{Binding SystemRestore}" />
                    </TabItem>
                    <TabItem Header="🔄 Windows Update Repair"
                             Visibility="{Binding WindowsUpdateRepair, Source={x:Static services:TabVisibilityService.Instance}}">
                        <views:WindowsUpdateRepairView />
                    </TabItem>
                    <TabItem Header="💻 Terminal"
                             Visibility="{Binding Terminal, Source={x:Static services:TabVisibilityService.Instance}}">
                        <views:LocalTerminalView/>
                    </TabItem>
                    <TabItem Header="📋 Job Queue"
                             Visibility="{Binding JobQueue, Source={x:Static services:TabVisibilityService.Instance}}">
                        <views:BatchJobQueueView/>
                    </TabItem>
                    <TabItem Header="Scheduled Backup"
                             Visibility="{Binding ScheduledBackup, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:ScheduledBackupView}" ViewDataContext="{Binding ScheduledBackup}" />
                    </TabItem>
                    <TabItem Header="Environment Variables"
                             Visibility="{Binding EnvironmentVariableManager, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:EnvironmentVariableManagerView}" ViewDataContext="{Binding EnvironmentVariableManager}" />
                    </TabItem>
                    <TabItem Header="Windows Services"
                             Visibility="{Binding WindowsServiceManager, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:WindowsServiceManagerView}" ViewDataContext="{Binding WindowsServiceManager}" />
                    </TabItem>
                    <TabItem Header="💽 Disk Health"
                             Visibility="{Binding DiskHealth, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:DiskHealthView}" ViewDataContext="{Binding DiskHealth}" />
                    </TabItem>
                    <TabItem Header="📶 WiFi Passwords"
                             Visibility="{Binding WifiPassword, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:WifiPasswordView}" ViewDataContext="{Binding WifiPassword}" />
                    </TabItem>
                    <TabItem Header="🌐 Remote Dashboard"
                             Visibility="{Binding RemoteDashboard, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:RemoteDashboardView}" ViewDataContext="{Binding RemoteDashboard}" />
                    </TabItem>
                    <TabItem Header="🖥️ Remote Desktop"
                             Visibility="{Binding RemoteDesktop, Source={x:Static services:TabVisibilityService.Instance}}">
                        <controls:LazyTabContent ViewType="{x:Type views:RemoteDesktopView}" ViewDataContext="{Binding RemoteDesktop}" />
                    </TabItem>
                    <!-- v4.0.3.10 reorg — Remote Hub (server, tunnel, fleet, treemap) — surfaces tools previously buried in Tools menu / Settings -->
                    <TabItem Header="🛰️ Remote Hub" AutomationProperties.Name="Remote Hub">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="24" MaxWidth="1100" HorizontalAlignment="Left">
                                <TextBlock Text="🛰️ Remote Hub" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Headless management, fleet monitoring, and disk visualization. Configure the remote server / Cloudflare Tunnel from Settings → Remote Control."
                                           TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,20"/>
                                <WrapPanel ItemWidth="340">
                                    <Border Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="📡 Remote Server / Tunnel" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
